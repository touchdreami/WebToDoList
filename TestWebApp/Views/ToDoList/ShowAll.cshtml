@model IEnumerable<TestWebApp.Models.ToDoTask>
@{
    ViewData["Title"] = "Показать все";
}

<div class="container mt-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Список задач</h1>
        <a asp-controller="ToDoList" asp-action="AddTask" class="btn btn-primary">Создать</a>
    </div>
    
    @if (!Model.Any())
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-info-circle"></i>
            📭 Задач пока нет. Создайте первую задачу!
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Статус</th>
                    <th>Начало выполнения</th>
                    <th>Срок выполнения</th>
                    <th>Действия</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var task in Model)
                {
                    <tr class="@(task.IsCompleted ? "table-success" : string.Empty)">
                        <td>@task.Id</td>
                        <td>
                            <strong>@task.Title</strong>
                        </td>
                        <td>@(string.IsNullOrEmpty(task.Description) ? "—" : task.Description)</td>
                        <td>
                            @if (task.IsCompleted)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Выполнено
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-white">
                                    <i class="bi bi-clock"></i> В процессе
                                </span>
                            }
                        </td>
                        <td>@task.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@task.EndDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="ToDoList" asp-action="EditTask" asp-route-id="@task.Id"
                               class="btn btn-sm btn-outline-dark">Редактировать</a>
                            <a asp-controller="ToDoList" asp-action="DeleteTask" asp-route-id="@task.Id"
                               class="btn btn-sm btn-outline-dark">Удалить</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <strong>Всего задач:</strong> @Model.Count() |
            <span class="text-success">Выполнено: @Model.Count(t => t.IsCompleted)</span>
        </div>
    }
</div>